{
  "name": "naologic-techtest",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "start": " ng serve --port 4200",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:ds": "ng build naologic-ds",
    "build:ds-watch": "ng build naologic-ds --watch",
    "start:db": "json-server --watch projects/json-db/db.json --routes projects/json-db/routes.json --port 3000",
    "start:dev": "npm-run-all build:ds start",
    "cypress:run": "cypress run --config-file projects/naologic-techtest/cypress.config.ts",
    "cypress:open": "cypress open --config-file projects/naologic-techtest/cypress.config.ts",
    "test:cli": "npm-run-all --parallel start:dev cypress:run",
    "test:interactive": "npm-run-all --parallel start:dev cypress:open",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "~21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "~21.2.1",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ng-select/ng-select": "^21.5.2",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/localize": "^21.2.0",
    "@angular/material": "^21.2.1",
    "@cypress/schematic": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "angular-eslint": "21.3.0",
    "cypress": "15.11.0",
    "eslint": "^10.0.2",
    "jsdom": "^28.0.0",
    "json-server": "0.17.4",
    "ng-packagr": "^21.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
